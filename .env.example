# Database
POSTGRES_USER=skylark
POSTGRES_PASSWORD=skylark_secret
POSTGRES_DB=skylark_vms
DATABASE_URL=postgresql://skylark:skylark_secret@postgres:5432/skylark_vms

# JWT
JWT_SECRET=change-me-in-production-use-a-real-secret

# Redis
REDIS_URL=redis://redis:6379

# Kafka
KAFKA_BROKERS=kafka:9092

# MediaMTX RTSP
RTSP_BASE_URL=rtsp://mediamtx:8554

# Backend
BACKEND_PORT=3000
BACKEND_URL=http://backend:3000

# Frontend
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# Worker
WORKER_INTERNAL_WS_URL=ws://backend:3000/internal/signaling

# Alert deduplication
ALERT_DEDUP_WINDOW_SECONDS=5
ALERT_RATE_LIMIT_PER_MINUTE=30
